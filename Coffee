<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Visit — Brew &amp; Co.</title>
<meta name="description" content="Hours, location, and a way to reach Brew &amp; Co.">
<link rel="stylesheet" href="css/style.css">
</head>
<body>

<header class="site-header">
  <nav class="nav">
    <a href="index.html" class="brand">
      <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <path d="M6 13h17v7a7 7 0 0 1-7 7H13a7 7 0 0 1-7-7v-7Z" stroke="currentColor" stroke-width="1.6"/>
        <path d="M23 15h2.5a3 3 0 0 1 0 6H23" stroke="currentColor" stroke-width="1.6"/>
        <path d="M11 9c-.8-1 .8-1.6 0-3M16 9c-.8-1 .8-1.6 0-3M21 9c-.8-1 .8-1.6 0-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      Brew &amp; Co.
    </a>
    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links">
      <li><a href="index.html">Home</a></li>
      <li><a href="menu.html">Menu</a></li>
      <li><a href="about.html">Our Story</a></li>
      <li><a href="contact.html" aria-current="page">Visit</a></li>
    </ul>
  </nav>
</header>

<section class="page-hero">
  <div class="container">
    <p class="eyebrow">Visit</p>
    <h1 style="font-size: clamp(2.2rem, 5vw, 3.4rem);">Come find the folding table</h1>
    <p>We're open early for the commute crowd and late for the ones who work best after dark.</p>
  </div>
</section>

<section class="section section--dark">
  <div class="container contact-grid">

    <div>
      <h2>Hours</h2>
      <table class="hours-table">
        <tr><td>Monday – Friday</td><td>7:00 – 19:00</td></tr>
        <tr><td>Saturday</td><td>8:00 – 20:00</td></tr>
        <tr><td>Sunday</td><td>9:00 – 17:00</td></tr>
      </table>

      <h2 style="margin-top: 2.5rem;">Find us</h2>
      <div class="map-block reveal">
        <div class="map-block__pin">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 22s7-6.6 7-12a7 7 0 1 0-14 0c0 5.4 7 12 7 12Z" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
          <span>12 Roastery Lane, Lagos</span>
        </div>
      </div>
    </div>

    <div>
      <h2>Send a message</h2>
      <p style="opacity:0.8;">Catering orders, wholesale beans, or just to say hi.</p>

      <form class="contact-form" novalidate>
        <div class="field">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required>
          <span class="field-error" data-error-for="name"></span>
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required>
          <span class="field-error" data-error-for="email"></span>
        </div>
        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" required></textarea>
          <span class="field-error" data-error-for="message"></span>
        </div>
        <button type="submit" class="btn btn--primary">Send message</button>
        <div class="form-status" role="status"></div>
      </form>
    </div>

  </div>
</section>

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <p class="brand" style="color: var(--parchment); margin-bottom: 0.75rem;">Brew &amp; Co.</p>
        <p style="opacity:0.7; max-width: 32ch;">Small-batch specialty coffee, roasted weekly and poured to order.</p>
      </div>
      <div>
        <h4>Explore</h4>
        <a href="menu.html">Menu</a>
        <a href="about.html">Our Story</a>
        <a href="contact.html">Visit</a>
      </div>
      <div>
        <h4>Follow</h4>
        <a href="#">Instagram</a>
        <a href="#">Twitter / X</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© <span id="year"></span> Brew &amp; Co. Coursework project — not a real business.</span>
      <span>Built with HTML, CSS &amp; JS</span>
    </div>
  </div>
</footer>

<script src="js/script.js"></script>
</body>
</html>
